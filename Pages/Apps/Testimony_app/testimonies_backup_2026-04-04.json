    "Clenmarreal": {
      "created": "2026-04-04T15:50:58.711Z",
      "entries": [
        {
          "id": 1775317858711,
          "seq": 1,
          "text": "I woke up today, having life, seeing my daughter and wife alive.\n\nDespite seeing rat excrement I am giving him thanks.\n\nThank you lord for having mercy on me",
          "date": "2026-04-04",
          "time": "12:50:56 PM",
          "iso": "2026-04-04T15:50:56.448Z",
          "imageUrl": "https://raw.githubusercontent.com/Clenmar/Storymaps/main/Pages/Apps/Testimony_app/media/images/Clenmarreal_1775317858711.jpg"
        },
        {
          "id": 1775326512092,
          "seq": 2,
          "text": "My daughter fell asleep in lap today, I thank God that she can sing, she can praise God, lift up her hands, say amen, even at this young age. \n\nGod you are good and your mercies endure forever",
          "date": "2026-04-04",
          "time": "3:15:09 PM",
          "iso": "2026-04-04T18:15:09.643Z",
          "imageUrl": "https://raw.githubusercontent.com/Clenmar/Storymaps/main/Pages/Apps/Testimony_app/media/images/Clenmarreal_1775326512092.jpg"
        }
      ]
    },
