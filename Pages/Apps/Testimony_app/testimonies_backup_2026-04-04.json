    "Shadzie": {
      "created": "2026-04-04T15:26:31.480Z",
      "entries": [
        {
          "id": 1775316391480,
          "seq": 1,
          "text": "I prayed for a changed life in 2021 and the lord answered within that same week!!!! I was not expecting it so soon. \n\nThank you Lord for all I have and a changed life. Thank you.",
          "date": "2026-04-04",
